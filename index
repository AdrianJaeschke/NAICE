<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>NAICE - 3D Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@200;300;400&family=Turret+Road:wght@200;400;700&display=swap" rel="stylesheet">
    
    <style>
        :root { --neon: #BBFF03; }
        *{margin:0;padding:0;box-sizing:border-box}
        body{background:#010103;overflow:hidden;font-family: "Barlow Condensed", sans-serif; font-weight: 300; color:#fff}
        
        #nav-bar { 
            position: absolute; top: 20px; left: 20px; z-index: 1000; 
            display: flex; align-items: center; gap: 15px; 
            background: rgba(0,0,0,0.6); padding: 10px; border-radius: 4px;
            border: 1px solid rgba(187,255,3,0.3); backdrop-filter: blur(15px);
        }
        
        #init-trigger {
            position: fixed; inset: 0; z-index: 9999; background: #010103;
            display: flex; justify-content: center; align-items: center;
            transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .loader-text { 
            color: var(--neon); font-size: 10px; letter-spacing: 8px; text-transform: uppercase;
            animation: pulse 1.5s infinite ease-in-out;
        }
        @keyframes pulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

        #hud-headline {
            display: none; position: fixed; top: 12%; left: 50%; transform: translateX(-50%);
            z-index: 1500; text-align: center; pointer-events: none; width: 90%;
        }
        #hud-headline h1 {
            font-family: "Turret Road", sans-serif; font-weight: 200; font-size: 5vw; 
            letter-spacing: 20px; color: var(--neon); text-transform: uppercase;
            text-shadow: 0 0 30px rgba(187,255,3,0.6); margin: 0;
        }

        #hud-overlay { display: none; position: fixed; top: 30px; right: 40px; z-index: 2000; }
        #close-hud { font-size: 35px; color: var(--neon); cursor: pointer; text-shadow: 0 0 10px var(--neon); }
        
        canvas { display: block; cursor: crosshair; }
    </style>
</head>
<body>

<div id="init-trigger">
    <div class="loader-text">CONNECTING TO REPOSITORY...</div>
</div>

<div id="nav-bar">
    <div id="logo-link" onclick="closeHUD()">
        <img src="assets/naice.png" alt="naice" style="height:35px; filter: drop-shadow(0 0 8px var(--neon)); cursor: pointer;">
    </div>
    <div class="breadcrumb">
        <span onclick="closeHUD()" style="cursor:pointer">HOME</span>
        <span id="case-label" style="display:none; color:var(--neon);"> / <span id="current-case-name"></span></span>
    </div>
</div>

<div id="hud-headline"><h1 id="headline-text">TITLE</h1></div>
<div id="hud-overlay"><div id="close-hud" onclick="closeHUD()">✕</div></div>

<canvas id="c"></canvas>

<script>
const GITHUB_USER = "AdrianJaeschke";
const GITHUB_REPO = "NAICE";

const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

let points = [], projects = [], collageImages = []; 
let rotX = 0.3, rotY = 0.5, zoom = 800;
let hudRotX = 0, hudRotY = 0; 
let mouse = { x: 0, y: 0 }, isDrag = false, lastMX, lastMY, activeCase = null; 

// 1. AUTOMATISCHES LADEN VON GITHUB
async function autoLoadPortfolio() {
    try {
        const response = await fetch(`https://api.github.com/repos/${GITHUB_USER}/${GITHUB_REPO}/contents/portfolio`);
        const contents = await response.json();
        const folders = contents.filter(item => item.type === 'dir');

        initAtmosphere();

        for (let folder of folders) {
            const folderResponse = await fetch(folder.url);
            const files = await folderResponse.json();

            const imageFiles = files.filter(f => f.name.match(/\.(jpg|jpeg|png)$/i));
            const textFile = files.find(f => f.name.endsWith('.txt'));

            if (imageFiles.length > 0) {
                const img = new Image();
                img.crossOrigin = "anonymous"; 
                img.src = imageFiles[0].download_url;
                await img.decode();

                let headline = folder.name;
                if (textFile) {
                    const txtRes = await fetch(textFile.download_url);
                    const rawText = await txtRes.text();
                    headline = rawText.split('\n')[0].trim();
                }

                projects.push({
                    name: folder.name,
                    headline: headline.toUpperCase(),
                    fullHeadline: headline.toUpperCase(),
                    cx: 0, cz: 0, focus: 0, img: img,
                    files: imageFiles.map(f => f.download_url)
                });
            }
        }

        // Layout berechnen
        projects.forEach((p, i) => {
            const angle = (i / projects.length) * Math.PI * 2;
            p.angle = angle;
            p.cx = Math.sin(angle) * 600;
            p.cz = Math.cos(angle) * 600;
            points.push(...extractPoints(p.img, p));
        });

        // Startbildschirm ausfaden
        document.getElementById('init-trigger').style.opacity = '0';
        setTimeout(() => document.getElementById('init-trigger').style.display = 'none', 1000);

    } catch (e) {
        console.error("Load Error:", e);
        document.querySelector('.loader-text').innerText = "CONNECTION ERROR";
    }
}

function initAtmosphere() {
    for(let i=0; i<7000; i++) {
        const r = 400 + Math.random() * 900;
        const t = Math.random() * Math.PI * 2, p = Math.acos(Math.random() * 2 - 1);
        points.push({ x: r*Math.sin(p)*Math.cos(t), y: r*Math.sin(p)*Math.sin(t), z: r*Math.cos(p),
                      r: 187, g: 255, b: 3, a: 0.12, size: 1, isBg: true });
    }
}

function extractPoints(img, proj) {
    const samples = 1800;
    const tempCv = document.createElement('canvas'); tempCv.width = tempCv.height = 64;
    const tCtx = tempCv.getContext('2d');
    tCtx.drawImage(img, 0, 0, 64, 64);
    const d = tCtx.getImageData(0,0,64,64).data;
    const pts = [];
    for(let i=0; i<samples; i++) {
        const u = Math.random(), v = Math.random();
        const tx = (u-0.5)*220, ty = (v-0.5)*220;
        const idx = (Math.floor(v*63)*64 + Math.floor(u*63))*4;
        pts.push({ cx: proj.cx, cz: proj.cz, angle: proj.angle,
            rx: Math.cos(Math.random()*Math.PI*2)*180, ry: Math.sin(Math.random()*Math.PI*2)*180, rz: (Math.random()-0.5)*220,
            tx, ty, tz: 0, r: d[idx], g: d[idx+1], b: d[idx+2], a: (d[idx+3]/255)*0.9,
            size: 1.8, parent: proj, isBg: false });
    }
    return pts;
}

function render() {
    canvas.width = window.innerWidth; canvas.height = window.innerHeight;
    ctx.fillStyle = '#010103'; ctx.fillRect(0,0,canvas.width,canvas.height);
    const cX = canvas.width / 2, cY = canvas.height / 2;

    rotY += 0.002;
    const cosY = Math.cos(rotY), sinY = Math.sin(rotY), cosX = Math.cos(rotX), sinX = Math.sin(rotX);

    if (!activeCase) {
        projects.forEach(p => {
            let x1 = p.cx*cosY+p.cz*sinY, z1 = p.cz*cosY-p.cx*sinY, y2 = -z1*sinX, z2 = z1*cosX;
            const s = zoom/(zoom+z2);
            const d = Math.sqrt((cX+x1*s-mouse.x)**2+(cY+y2*s-mouse.y)**2);
            p.focus = (d<140*s)?Math.min(1,p.focus+0.07) : Math.max(0,p.focus-0.07);
        });

        points.map(p => {
            let x,y,z;
            if(p.isBg){x=p.x;y=p.y;z=p.z}
            else {
                const f=p.parent.focus;
                const lx=p.rx*(1-f)+p.tx*f, ly=p.ry*(1-f)+p.ty*f, lz=p.rz*(1-f);
                x=p.cx+(lx*Math.cos(-p.angle)+lz*Math.sin(-p.angle)); y=ly; z=p.cz+(lz*Math.cos(-p.angle)-lx*Math.sin(-p.angle));
            }
            let x1=x*cosY+z*sinY, z1=z*cosY-x*sinY, y2=y*cosX-z1*sinX, z2=z1*cosX+y*sinX;
            const s=zoom/(zoom+z2);
            return {px:cX+x1*s, py:cY+y2*s, pz:z2, size:p.size*s, 
                    color:`rgba(${p.r},${p.g},${p.b},${p.isBg?p.a:p.a*(0.5+p.parent.focus*0.5)})`};
        }).filter(p=>p.pz>-zoom).sort((a,b)=>b.pz-a.pz).forEach(p=>{ctx.fillStyle=p.color; ctx.fillRect(p.px,p.py,p.size,p.size)});

        projects.forEach(p=>{ 
            let x1=p.cx*cosY+p.cz*sinY, z1=p.cz*cosY-p.cx*sinY, y2=-z1*sinX, z2=z1*cosX;
            const s=zoom/(zoom+z2);
            ctx.save(); ctx.translate(cX+x1*s,cY+y2*s); 
            if(p.focus>0.01){
                ctx.globalAlpha=Math.pow(p.focus,4);
                ctx.drawImage(p.img,-110*s,-110*s,220*s,220*s); 
            }
            // Text ist immer da, wird bei Focus heller
            ctx.globalAlpha = 0.3 + (p.focus * 0.7);
            ctx.fillStyle = p.focus > 0.5 ? "var(--neon)" : "#fff";
            ctx.font = `300 ${10 * s}px "Barlow Condensed"`;
            ctx.textAlign = "center";
            ctx.letterSpacing = "4px";
            ctx.fillText(p.headline, 0, 12);
            ctx.restore();
        });
    } else {
        renderHUD(cX, cY);
    }
    requestAnimationFrame(render);
}

function renderHUD(cX, cY) {
    hudRotY += ((mouse.x-cX)*0.0004-hudRotY)*0.1;
    hudRotX += (-(mouse.y-cY)*0.0004-hudRotX)*0.1;
    const hCosY=Math.cos(hudRotY), hSinY=Math.sin(hudRotY), hCosX=Math.cos(hudRotX), hSinX=Math.sin(hudRotX);

    collageImages.map(imgObj => {
        let x1=imgObj.x*hCosY+imgObj.z*hSinY, z1=imgObj.z*hCosY-imgObj.x*hSinY;
        let y2=imgObj.y*hCosX-z1*hSinX, z2=z1*hCosX+imgObj.y*hSinX;
        return {...imgObj, x1, y2, z2};
    }).sort((a,b)=>b.z2-a.z2).forEach(imgObj => {
        const scale = 1000/(1000+imgObj.z2);
        const finalW = imgObj.aspect>1 ? imgObj.baseSize*scale : imgObj.baseSize*scale*imgObj.aspect;
        const finalH = imgObj.aspect>1 ? (imgObj.baseSize*scale)/imgObj.aspect : imgObj.baseSize*scale;
        ctx.save(); ctx.translate(cX+imgObj.x1*scale, cY+imgObj.y2*scale);
        ctx.rotate(hudRotY*0.2 + imgObj.randomRot); ctx.globalAlpha=0.98;
        ctx.drawImage(imgObj.el, -finalW/2, -finalH/2, finalW, finalH); ctx.restore();
    });
    document.getElementById('headline-text').style.transform=`perspective(1000px) rotateY(${hudRotY*20}deg) rotateX(${hudRotX*20}deg)`;
}

async function openCaseHUD(p) {
    activeCase = p;
    document.getElementById('headline-text').innerText = p.fullHeadline;
    document.getElementById('hud-headline').style.display = "block";
    document.getElementById('case-label').style.display = "inline";
    document.getElementById('current-case-name').innerText = p.name.toUpperCase();
    document.getElementById('hud-overlay').style.display = "block";
    
    collageImages = [];
    for(let [i, url] of p.files.entries()) {
        const img = new Image(); img.crossOrigin = "anonymous"; img.src = url; await img.decode();
        const isLead = i===0;
        collageImages.push({
            el: img, aspect: img.width/img.height,
            x: isLead?0:Math.cos(Math.random()*Math.PI*2)*500,
            y: isLead?60:Math.sin(Math.random()*Math.PI*2)*500,
            z: isLead?-300:Math.random()*450+100,
            baseSize: isLead?550:280, randomRot: isLead?0:(Math.random()-0.5)*0.2
        });
    }
}

function closeHUD() {
    activeCase=null; document.getElementById('hud-headline').style.display="none";
    document.getElementById('case-label').style.display="none"; document.getElementById('hud-overlay').style.display="none";
    collageImages=[];
}

canvas.onmousemove=e=>{mouse.x=e.clientX;mouse.y=e.clientY};
canvas.onmousedown=e=>{
    isDrag=false;lastMX=e.clientX;lastMY=e.clientY;
    const mm=ev=>{
        if(Math.abs(ev.clientX-lastMX)>5)isDrag=true;
        rotY+=(ev.clientX-lastMX)*0.005;
        rotX+=(ev.clientY-lastMY)*0.005;
        lastMX=ev.clientX;lastMY=ev.clientY;
    };
    const mu=()=>{window.removeEventListener('mousemove',mm);window.removeEventListener('mouseup',mu)};
    window.addEventListener('mousemove',mm);window.addEventListener('mouseup',mu);
};
canvas.onclick=()=>{if(!isDrag&&!activeCase){const active=projects.find(p=>p.focus>0.7);if(active)openCaseHUD(active)}};
canvas.addEventListener('wheel',e=>{e.preventDefault();if(!activeCase)zoom-=e.deltaY;},{passive:false});

window.onload = autoLoadPortfolio;
render();
</script>
</body>
</html>
